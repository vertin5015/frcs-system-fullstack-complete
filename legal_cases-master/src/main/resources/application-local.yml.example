# 本地开发：复制为 application-local.yml 后按你本机修改，不要提交含密码的文件到 Git
# 启动：.\mvnw.cmd spring-boot:run -Dspring-boot.run.arguments="--spring.profiles.active=local"
# 或在 IDEA Run Configuration 里加 VM options：-Dspring.profiles.active=local

spring:
  datasource:
    url: jdbc:mysql://127.0.0.1:3306/legal_cases?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8&connectionCollation=utf8_general_ci
    username: root
    password: 你的本机MySQL密码
  data:
    redis:
      host: 127.0.0.1
      port: 6379
      password: # 无密码则留空或删掉该行
      database: 0

# 爬虫若连不上远程，改为你内网可访问的地址；列表搜索与详情是不同端口；key 与 CountryEnum 一致（大写）
# 端口与请求示例见：scripts/crawler-endpoints.txt ；自检：scripts/verify-crawler-ports.ps1
# crawler:
#   detail-url: "http://127.0.0.1:9001/crawl.json"
#   search:
#     US: "http://127.0.0.1:9003/crawl.json"
#     # 默认 EU/JPN 可走后端内置 bridge（8122）；外置爬虫时改回 9002 / 9004
#     EU: "http://127.0.0.1:8122/api/crawler-bridge/list/EU/crawl.json"
#     JPN: "http://127.0.0.1:8122/api/crawler-bridge/list/JPN/crawl.json"
