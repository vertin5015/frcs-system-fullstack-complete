<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hnu.legal_cases.dao.UsageLogMapper">
    <insert id="insert" parameterType="com.hnu.legal_cases.pojo.UsageLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO usage_log (user_id, case_id, action_type)
        VALUES (#{userId}, #{caseId}, #{actionType})
    </insert>
</mapper>
