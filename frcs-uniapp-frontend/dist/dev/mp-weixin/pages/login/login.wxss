.page-container.data-v-cdfe2409 {
  min-height: 100vh;
  background: linear-gradient(180deg, #E6F0FF 0%, #F5FAFF 40%, #FFFFFF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
  position: relative;
}

/* 顶部信息 */
.header.data-v-cdfe2409 {
  margin-top: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.header .logo.data-v-cdfe2409 {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background-color: #218cff;
  margin-bottom: 30rpx;
}
.header .title.data-v-cdfe2409 {
  font-size: 48rpx;
  font-weight: 600;
  color: #333333;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}
.header .subtitle.data-v-cdfe2409 {
  font-size: 24rpx;
  color: #999999;
  font-weight: 500;
  margin-bottom: 60rpx;
}

/* 登录卡片 */
.login-card.data-v-cdfe2409 {
  width: 100%;
  background-color: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(37, 99, 235, 0.06);
  padding: 50rpx 40rpx;
  box-sizing: border-box;
}

/* 统一单选圆圈样式 */
.radio-icon.data-v-cdfe2409 {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 3rpx solid #cccccc;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}
.radio-icon.active.data-v-cdfe2409 {
  border-color: #218cff;
  position: relative;
}
.radio-icon.active.data-v-cdfe2409::after {
  content: "";
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: #218cff;
}

/* Tabs 切换 */
.login-tabs.data-v-cdfe2409 {
  display: flex;
  justify-content: center;
  gap: 80rpx;
  margin-bottom: 50rpx;
}
.login-tabs .tab-item.data-v-cdfe2409 {
  display: flex;
  align-items: center;
}
.login-tabs .tab-item .tab-text.data-v-cdfe2409 {
  font-size: 30rpx;
  color: #999999;
  font-weight: 500;
  transition: color 0.2s;
}
.login-tabs .tab-item .text-active.data-v-cdfe2409 {
  color: #218cff;
  font-weight: 600;
}

/* 表单输入区域 */
.form-area.data-v-cdfe2409 {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}
.form-area .input-box.data-v-cdfe2409 {
  display: flex;
  align-items: center;
  background-color: #f6f6f6;
  height: 96rpx;
  border-radius: 48rpx;
  padding: 0 30rpx;
}
.form-area .input-box .icon-placeholder.data-v-cdfe2409 {
  font-size: 32rpx;
  color: #b3b3b3;
  margin-right: 20rpx;
}
.form-area .input-box .input-field.data-v-cdfe2409 {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333;
}
.form-area .input-box-group.data-v-cdfe2409 {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.form-area .input-box-group .code-input.data-v-cdfe2409 {
  flex: 1;
}
.form-area .input-box-group .get-code-btn.data-v-cdfe2409 {
  width: 220rpx;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #218cff;
  color: #ffffff;
  font-size: 26rpx;
  border-radius: 48rpx;
  margin: 0;
  padding: 0;
}
.form-area .input-box-group .get-code-btn.data-v-cdfe2409::after {
  border: none;
}
.form-area .input-box-group .get-code-btn[disabled].data-v-cdfe2409 {
  background-color: #a0cfff;
  color: #ffffff;
}

/* placeholder 颜色覆盖 */
.data-v-cdfe2409 .ph-color {
  color: #cccccc;
}

/* 链接区域 */
.action-links.data-v-cdfe2409 {
  display: flex;
  justify-content: space-between;
  margin-top: 30rpx;
  margin-bottom: 50rpx;
  padding: 0 10rpx;
}
.action-links .link-gray.data-v-cdfe2409 {
  font-size: 24rpx;
  color: #999999;
}

/* 提交按钮 */
.submit-btn.data-v-cdfe2409 {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #218cff;
  border-radius: 48rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(33, 140, 255, 0.3);
}
.submit-btn.data-v-cdfe2409::after {
  border: none;
}
.submit-btn.data-v-cdfe2409:active {
  opacity: 0.8;
}

/* 微信文本登录 */
.wechat-login.data-v-cdfe2409 {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}
.wechat-login .line.data-v-cdfe2409 {
  width: 60rpx;
  height: 1px;
  background-color: #eeeeee;
}
.wechat-login .wechat-text.data-v-cdfe2409 {
  font-size: 24rpx;
  color: #999999;
  margin: 0 20rpx;
}

/* 游客访问 */
.guest-access.data-v-cdfe2409 {
  margin-top: 40rpx;
}
.guest-access .guest-text.data-v-cdfe2409 {
  font-size: 24rpx;
  color: #999999;
  border-bottom: 1px solid #cccccc;
  padding-bottom: 4rpx;
}

/* 底部协议 */
.terms-area.data-v-cdfe2409 {
  position: absolute;
  bottom: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}
.terms-area .checkbox-wrapper.data-v-cdfe2409 {
  padding: 10rpx;
}
.terms-area .radio-icon.data-v-cdfe2409 {
  margin-right: 6rpx;
  width: 24rpx;
  height: 24rpx;
}
.terms-area .radio-icon.active.data-v-cdfe2409::after {
  width: 12rpx;
  height: 12rpx;
}
.terms-area .terms-text.data-v-cdfe2409 {
  font-size: 24rpx;
  color: #999999;
}
.terms-area .terms-link.data-v-cdfe2409 {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

/* 重置密码弹窗样式 */
.modal-overlay.data-v-cdfe2409 {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-card.data-v-cdfe2409 {
  width: 80%;
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 50rpx 40rpx;
  box-sizing: border-box;
  animation: scaleUp-cdfe2409 0.3s ease-out;
}
.modal-header.data-v-cdfe2409 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 50rpx;
}
.modal-header .modal-title.data-v-cdfe2409 {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}
.modal-header .close-btn.data-v-cdfe2409 {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #218cff;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-header .close-btn .close-icon.data-v-cdfe2409 {
  font-size: 34rpx;
  color: #218cff;
  line-height: 1;
  margin-top: -4rpx;
}
.modal-footer.data-v-cdfe2409 {
  display: flex;
  justify-content: center;
  margin-top: 50rpx;
}
.modal-footer .reset-confirm-btn.data-v-cdfe2409 {
  width: 260rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0;
}
@keyframes scaleUp-cdfe2409 {
from {
    transform: scale(0.9);
    opacity: 0;
}
to {
    transform: scale(1);
    opacity: 1;
}
}