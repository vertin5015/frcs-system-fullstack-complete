# Copy this file to .env on the server before running docker compose.

MYSQL_ROOT_PASSWORD=frcs123456
MYSQL_PORT=3306
REDIS_PORT=6379
BACKEND_PORT=8122
WEB_PORT=80

# Default: OpenAI-compatible Ollama service on the Docker host.
# If you use DeepSeek/OpenAI-compatible APIs, replace these three values.
SPRING_AI_OPENAI_API_KEY=ollama
SPRING_AI_OPENAI_BASE_URL=http://host.docker.internal:11434
SPRING_AI_OPENAI_CHAT_OPTIONS_MODEL=qwen2.5:7b-instruct

APP_ADMIN_SECRET=frcs-admin-change-me

# Optional external crawler services. Defaults are enough for the built-in EU/JPN bridge.
CRAWLER_DETAIL_URL=http://host.docker.internal:9001/crawl.json
CRAWLER_SEARCH_US_URL=http://host.docker.internal:9003/crawl.json
